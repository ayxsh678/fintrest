# ── Go Gateway ─────────────────────────────────────────────────────────────
# Required
JWT_SECRET=                     # strong random string (e.g. openssl rand -hex 32)
DATABASE_URL=                   # postgres://user:pass@host:5432/dbname

# Optional (defaults shown)
PORT=8000
PYTHON_SERVICE_URL=http://localhost:8001
ALLOWED_ORIGIN=                 # production frontend URL (e.g. https://yourapp.vercel.app)

# Email alerts (all required if you want email notifications)
SMTP_USER=                      # e.g. you@gmail.com
SMTP_PASS=                      # Gmail app password or SMTP password
SMTP_HOST=smtp.gmail.com        # override for non-Gmail providers
SMTP_PORT=587                   # override if needed
ALERT_EMAIL=                    # address that receives alert emails

# ── Python Service ──────────────────────────────────────────────────────────
# Required
GROQ_API_KEY=                   # from console.groq.com
NEWS_API_KEY=                   # from newsapi.org

# Optional
OPEN_EXCHANGE_RATES_KEY=        # from openexchangerates.org (forex feature)
REDIS_URL=redis://localhost:6379 # conversation memory (degraded gracefully if absent)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173  # comma-separated

# ── Frontend ────────────────────────────────────────────────────────────────
REACT_APP_API_URL=https://fintrest-go.onrender.com  # Go gateway URL
